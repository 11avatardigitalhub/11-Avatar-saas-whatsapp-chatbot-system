            <div id="payment_fields">
                <div class="form-group">
                    <label class="form-label">Stripe Price ID</label>
                    <input type="text" class="form-control" name="stripe_price_id" placeholder="price_...">
                    <small class="form-text">ID do preço criado no Stripe (obrigatório se Stripe estiver ativo)</small>
                </div>
                <div class="form-group">
                    <label class="form-label">PayPal Plan ID</label>
                    <input type="text" class="form-control" name="paypal_plan_id" placeholder="P-...">
                    <small class="form-text">ID do plano de assinatura criado no PayPal (obrigatório se PayPal estiver ativo)</small>
                </div>
            </div>
        </form>

        <style>
            .switch-label {
                display: flex;
                align-items: center;
                cursor: pointer;
                user-select: none;
            }
            .switch-label input[type="checkbox"] {
                margin-right: 10px;
                width: 18px;
                height: 18px;
                cursor: pointer;
            }
            .switch-label span {
                font-weight: 500;
            }
            .row {
                display: flex;
                gap: 1rem;
                margin-bottom: 1rem;
            }
            .col-md-4 {
                flex: 1;
                min-width: 0;
            }
            .col-md-6 {
                flex: 1;
                min-width: 0;
            }
            .form-text {
                display: block;
                margin-top: 0.25rem;
                font-size: 0.875rem;
                color: #6c757d;
            }
        </style>

        <script>
            function toggleInvoiceLimit() {
                const enabled = document.getElementById('invoices_enabled').checked;
                document.getElementById('invoice_limit_group').style.display = enabled ? 'block' : 'none';
                if (enabled) {
                    document.querySelector('input[name="max_invoices_per_month"]').value = 10;
                }
            }
            function toggleQuoteLimit() {
                const enabled = document.getElementById('quotes_enabled').checked;
                document.getElementById('quote_limit_group').style.display = enabled ? 'block' : 'none';
                if (enabled) {
                    document.querySelector('input[name="max_quotes_per_month"]').value = 10;
                }
            }
            function toggleWidgetLimit() {
                const enabled = document.getElementById('widgets_enabled').checked;
                document.getElementById('widget_limit_group').style.display = enabled ? 'block' : 'none';
                if (enabled) {
                    document.querySelector('input[name="max_widgets"]').value = 3;
                }
            }
            function togglePaymentLinkLimit() {
                const enabled = document.getElementById('payment_links_enabled').checked;
                document.getElementById('payment_link_limit_group').style.display = enabled ? 'block' : 'none';
                if (enabled) {
                    document.querySelector('input[name="max_payment_links_per_month"]').value = 50;
                }
            }
            function togglePaymentFields() {
                const isFree = document.getElementById('is_free').checked;
                document.getElementById('payment_fields').style.display = isFree ? 'none' : 'block';
            }
        </script>
    `;

    const footer = `
        <button class="btn btn-secondary" onclick="closeModal()">Cancelar</button>
        <button class="btn btn-primary" onclick="submitCreatePlan()">Criar Plano</button>
    `;

    createModal('Criar Plano de Assinatura', content, footer);
}

async function submitCreatePlan() {
    const form = document.getElementById('createPlanForm');
    const formData = new FormData(form);
    const data = {};
    
    // Process all form fields
    for (const [key, value] of formData.entries()) {
        data[key] = value;
    }
    
    // Process checkboxes (they won't be in formData if unchecked)
    const checkboxes = [
        'whatsapp_enabled', 'ai_enabled', 'woocommerce_enabled', 'analytics_enabled',
        'priority_support_enabled', 'api_access_enabled', 'custom_branding_enabled',
        'invoices_enabled', 'quotes_enabled', 'widgets_enabled', 'payment_links_enabled',
        'is_free'
    ];
    
    checkboxes.forEach(checkbox => {
        const element = form.querySelector(`input[name="${checkbox}"]`);
        data[checkbox] = element ? element.checked : false;
    });

    // Validate payment IDs if not free plan
    if (!data.is_free) {
        if (!data.stripe_price_id && !data.paypal_plan_id) {
            alert('Para planos pagos, você deve fornecer pelo menos um ID de pagamento (Stripe ou PayPal)');
            return;
        }
    }

    try {
        await apiRequest('/superadmin/plans', {
            method: 'POST',
            body: JSON.stringify(data)
        });

        closeModal();
        showSuccess('Plano criado com sucesso!');
        loadPlans();
    } catch (error) {
        alert('Erro: ' + error.message);
    }
}

async function editPlan(id) {
    try {
        const response = await apiRequest('/superadmin/plans');
        const plan = (response.data || []).find(p => p.id === id);

        const content = `
            <form id="editPlanForm">
                <h3 style="margin-top: 0; color: var(--primary);">Informações Básicas</h3>
                <div class="form-group">
                    <label class="form-label">Nome do Plano</label>
                    <input type="text" class="form-control" name="name" value="${plan.name}">
                </div>
                <div class="form-group">
                    <label class="form-label">Descrição</label>
                    <textarea class="form-control" name="description" rows="3">${plan.description || ''}</textarea>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Preço</label>
                            <input type="number" class="form-control" name="price" step="0.01" value="${plan.price}">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Moeda</label>
                            <select class="form-control" name="currency">
                                <option value="USD" ${plan.currency === 'USD' ? 'selected' : ''}>USD</option>
                                <option value="EUR" ${plan.currency === 'EUR' ? 'selected' : ''}>EUR</option>
                                <option value="GBP" ${plan.currency === 'GBP' ? 'selected' : ''}>GBP</option>
                                <option value="BRL" ${plan.currency === 'BRL' ? 'selected' : ''}>BRL</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Período</label>
                            <select class="form-control" name="billing_period">
                                <option value="monthly" ${plan.billing_period === 'monthly' ? 'selected' : ''}>Mensal</option>
                                <option value="yearly" ${plan.billing_period === 'yearly' ? 'selected' : ''}>Anual</option>
