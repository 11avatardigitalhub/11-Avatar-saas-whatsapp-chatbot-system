                    </div>
                </div>
            </div>

            <hr>
            <h3 style="color: var(--primary);">Widgets e Links de Pagamento</h3>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="switch-label">
                            <input type="checkbox" name="widgets_enabled" id="widgets_enabled" onchange="toggleWidgetLimit()">
                            <span>Widgets Habilitados</span>
                        </label>
                    </div>
                    <div class="form-group" id="widget_limit_group" style="display: none;">
                        <label class="form-label">Máx. Widgets</label>
                        <input type="number" class="form-control" name="max_widgets" value="0" min="0">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="switch-label">
