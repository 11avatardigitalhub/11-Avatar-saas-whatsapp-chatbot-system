                    </div>
                    <div class="form-group" id="payment_link_limit_group" style="display: none;">
                        <label class="form-label">Máx. Links/Mês</label>
                        <input type="number" class="form-control" name="max_payment_links_per_month" value="0" min="0">
                    </div>
                </div>
            </div>

            <hr>
            <h3 style="color: var(--primary);">Integração com Gateways de Pagamento</h3>
            <div class="form-group">
                <label class="switch-label">
                    <input type="checkbox" name="is_free" id="is_free" onchange="togglePaymentFields()">
                    <span>Plano Gratuito</span>
                </label>
                <small class="form-text">Se marcado, não é necessário configurar IDs de pagamento</small>
