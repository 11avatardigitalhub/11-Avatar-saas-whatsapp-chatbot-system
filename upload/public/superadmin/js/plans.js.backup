                        </div>
                        <div class="form-group">
                            <label class="switch-label">
                                <input type="checkbox" name="api_access_enabled" ${plan.api_access_enabled ? 'checked' : ''}>
                                <span>Acesso à API</span>
                            </label>
                        </div>
                        <div class="form-group">
                            <label class="switch-label">
                                <input type="checkbox" name="custom_branding_enabled" ${plan.custom_branding_enabled ? 'checked' : ''}>
                                <span>Marca Personalizada</span>
                            </label>
                        </div>
                    </div>
                </div>

                <hr>
                <h3 style="color: var(--primary);">Faturas e Orçamentos</h3>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="switch-label">
                                <input type="checkbox" name="invoices_enabled" id="edit_invoices_enabled" ${plan.invoices_enabled ? 'checked' : ''} onchange="toggleEditInvoiceLimit()">
                                <span>Faturas Habilitadas</span>
                            </label>
                        </div>
                        <div class="form-group" id="edit_invoice_limit_group" style="display: ${plan.invoices_enabled ? 'block' : 'none'};">
                            <label class="form-label">Máx. Faturas/Mês</label>
                            <input type="number" class="form-control" name="max_invoices_per_month" value="${plan.max_invoices_per_month || 0}">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="switch-label">
                                <input type="checkbox" name="quotes_enabled" id="edit_quotes_enabled" ${plan.quotes_enabled ? 'checked' : ''} onchange="toggleEditQuoteLimit()">
                                <span>Orçamentos Habilitados</span>
                            </label>
                        </div>
                        <div class="form-group" id="edit_quote_limit_group" style="display: ${plan.quotes_enabled ? 'block' : 'none'};">
                            <label class="form-label">Máx. Orçamentos/Mês</label>
                            <input type="number" class="form-control" name="max_quotes_per_month" value="${plan.max_quotes_per_month || 0}">
                        </div>
                    </div>
                </div>

                <hr>
                <h3 style="color: var(--primary);">Widgets e Links de Pagamento</h3>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="switch-label">
                                <input type="checkbox" name="widgets_enabled" id="edit_widgets_enabled" ${plan.widgets_enabled ? 'checked' : ''} onchange="toggleEditWidgetLimit()">
                                <span>Widgets Habilitados</span>
                            </label>
                        </div>
                        <div class="form-group" id="edit_widget_limit_group" style="display: ${plan.widgets_enabled ? 'block' : 'none'};">
                            <label class="form-label">Máx. Widgets</label>
                            <input type="number" class="form-control" name="max_widgets" value="${plan.max_widgets || 0}">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="switch-label">
                                <input type="checkbox" name="payment_links_enabled" id="edit_payment_links_enabled" ${plan.payment_links_enabled ? 'checked' : ''} onchange="toggleEditPaymentLinkLimit()">
                                <span>Links de Pagamento Habilitados</span>
                            </label>
                        </div>
                        <div class="form-group" id="edit_payment_link_limit_group" style="display: ${plan.payment_links_enabled ? 'block' : 'none'};">
                            <label class="form-label">Máx. Links/Mês</label>
                            <input type="number" class="form-control" name="max_payment_links_per_month" value="${plan.max_payment_links_per_month || 0}">
                        </div>
                    </div>
                </div>

                <hr>
                <div class="form-group">
                    <label class="form-label">Status</label>
                    <select class="form-control" name="active">
                        <option value="1" ${plan.active ? 'selected' : ''}>Ativo</option>
                        <option value="0" ${!plan.active ? 'selected' : ''}>Inativo</option>
                    </select>
                </div>
            </form>

            <style>
                .switch-label {
                    display: flex;
                    align-items: center;
                    cursor: pointer;
                    user-select: none;
                }
                .switch-label input[type="checkbox"] {
                    margin-right: 10px;
                    width: 18px;
                    height: 18px;
                    cursor: pointer;
                }
                .switch-label span {
                    font-weight: 500;
                }
                .row {
                    display: flex;
                    gap: 1rem;
                    margin-bottom: 1rem;
                }
                .col-md-4 {
                    flex: 1;
                    min-width: 0;
                }
                .col-md-6 {
                    flex: 1;
                    min-width: 0;
                }
            </style>

            <script>
                function toggleEditInvoiceLimit() {
                    const enabled = document.getElementById('edit_invoices_enabled').checked;
                    document.getElementById('edit_invoice_limit_group').style.display = enabled ? 'block' : 'none';
                }
                function toggleEditQuoteLimit() {
                    const enabled = document.getElementById('edit_quotes_enabled').checked;
                    document.getElementById('edit_quote_limit_group').style.display = enabled ? 'block' : 'none';
                }
                function toggleEditWidgetLimit() {
                    const enabled = document.getElementById('edit_widgets_enabled').checked;
                    document.getElementById('edit_widget_limit_group').style.display = enabled ? 'block' : 'none';
                }
                function toggleEditPaymentLinkLimit() {
                    const enabled = document.getElementById('edit_payment_links_enabled').checked;
                    document.getElementById('edit_payment_link_limit_group').style.display = enabled ? 'block' : 'none';
                }
            </script>
        `;

        const footer = `
            <button class="btn btn-secondary" onclick="closeModal()">Cancelar</button>
            <button class="btn btn-primary" onclick="submitEditPlan(${id})">Atualizar</button>
        `;

        createModal('Editar Plano', content, footer);
    } catch (error) {
        alert('Erro: ' + error.message);
    }
}

async function submitEditPlan(id) {
    const form = document.getElementById('editPlanForm');
    const formData = new FormData(form);
    const data = {};
    
    // Process all form fields
    for (const [key, value] of formData.entries()) {
        data[key] = value;
    }
    
    // Process checkboxes
    const checkboxes = [
        'whatsapp_enabled', 'ai_enabled', 'woocommerce_enabled', 'analytics_enabled',
        'priority_support_enabled', 'api_access_enabled', 'custom_branding_enabled',
        'invoices_enabled', 'quotes_enabled', 'widgets_enabled', 'payment_links_enabled'
    ];
    
    checkboxes.forEach(checkbox => {
        const element = form.querySelector(`input[name="${checkbox}"]`);
        data[checkbox] = element ? element.checked : false;
    });

    try {
        await apiRequest(`/superadmin/plans/${id}`, {
            method: 'PUT',
            body: JSON.stringify(data)
        });

        closeModal();
        showSuccess('Plano atualizado com sucesso!');
        loadPlans();
    } catch (error) {
        alert('Erro: ' + error.message);
    }
}

function deletePlan(id, name, tenantCount) {
    if (tenantCount > 0) {
        alert(`Cannot delete plan "${name}" because it has ${tenantCount} active tenant(s).`);
        return;
    }

    if (confirm(`Are you sure you want to delete plan "${name}"?`)) {
        apiRequest(`/superadmin/plans/${id}`, {
            method: 'DELETE'
        }).then(() => {
            showSuccess('Plan deleted successfully!');
            loadPlans();
        }).catch(error => {
            alert('Error: ' + error.message);
        });
    }
}
