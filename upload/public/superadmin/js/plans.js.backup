                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Sort Order</label>
                        <input type="number" class="form-control" name="sort_order" value="0">
                    </div>
                </div>
            </div>

            <hr>
            <h3 style="color: var(--primary);">Features</h3>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="switch-label">
