# ============================================
# MISAYAN SAAS - MULTI-TENANT WHATSAPP BUSINESS PLATFORM
# ============================================
# Copy this file to .env and configure all required settings
# Generate secure secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ============================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=misayan

# ============================================
# SECURITY CONFIGURATION (REQUIRED)
# ============================================
# JWT Secret - Generate a strong random string (minimum 32 characters)
# IMPORTANT: Change this before deploying to production!
JWT_SECRET=your_very_strong_random_secret_key_minimum_32_characters

# Encryption key for sensitive data (32 characters)
ENCRYPTION_KEY=your_32_character_encryption_key_here

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development

# Application URL (used for generating public links)
# IMPORTANT: Set this to your production domain
# Example: https://yourdomain.com
APP_URL=http://localhost:3000

# Trust proxy setting for reverse proxies (nginx, Apache, etc.)
# Options: true, false, or specific IP addresses
TRUST_PROXY=loopback

# CORS allowed origins (comma-separated)
# Example: https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# ============================================
# SUPER ADMIN CONFIGURATION (REQUIRED)
# ============================================
SUPER_ADMIN_EMAIL=admin@saas.misayan.cloud
SUPER_ADMIN_PASSWORD=ChangeThisPassword123!

# ============================================
# PAYMENT GATEWAYS (REQUIRED FOR SAAS)
# ============================================

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# PagBank Configuration (API v4)
# Get your token at: https://minhaconta.pagseguro.uol.com.br/
# Token format: XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
PAGBANK_EMAIL=your_email@example.com
PAGBANK_TOKEN=your_pagbank_api_v4_token
PAGBANK_SANDBOX=true

# ============================================
# EMAIL CONFIGURATION (OPTIONAL)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
SMTP_FROM=noreply@saas.misayan.cloud

# ============================================
# LOGGING CONFIGURATION
# ============================================
# Log level: error, warn, info, http, debug
LOG_LEVEL=info

# ============================================
# PUSH NOTIFICATIONS (OPTIONAL)
# ============================================
# Generate VAPID keys using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@yourdomain.com

# ============================================
# SAAS CONFIGURATION
# ============================================
# Default tenant limits
DEFAULT_MAX_USERS=5
DEFAULT_MAX_CONVERSATIONS=1000
DEFAULT_MAX_MESSAGES_PER_MONTH=10000

# Trial period (days)
TRIAL_PERIOD_DAYS=14

# Session configuration
SESSION_SECRET=your_session_secret_key_here
SESSION_MAX_AGE=86400000

# ============================================
# RTL (RIGHT-TO-LEFT) CONFIGURATION
# ============================================
# Enable RTL support globally
RTL_ENABLED=false

# Default language (affects initial direction)
DEFAULT_LANGUAGE=en

# Auto-detect direction from language
RTL_AUTO_DETECT=true
